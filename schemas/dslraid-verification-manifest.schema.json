{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://dslraid.dev/schemas/dslraid-verification-manifest.schema.json",
    "title": "DSLRaid Verification Manifest",
    "oneOf": [
        {
            "type": "object",
            "required": [
                "manifest_version",
                "generated_by",
                "subject",
                "source",
                "visibility",
                "public_surface_roots",
                "rules"
            ],
            "additionalProperties": false,
            "properties": {
                "manifest_version": {
                    "$ref": "#/$defs/semver"
                },
                "generated_by": {
                    "const": "scripts/verificationprivacygen.sh"
                },
                "subject": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "source": {
                    "$ref": "#/$defs/path"
                },
                "visibility": {
                    "const": "public"
                },
                "public_surface_roots": {
                    "$ref": "#/$defs/strings"
                },
                "rules": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/status_rule"
                    }
                }
            }
        },
        {
            "type": "object",
            "required": [
                "manifest_version",
                "generated_by",
                "subject",
                "source",
                "loop",
                "closure_rules"
            ],
            "additionalProperties": false,
            "properties": {
                "manifest_version": {
                    "$ref": "#/$defs/semver"
                },
                "generated_by": {
                    "const": "scripts/verificationpdcagen.sh"
                },
                "subject": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "source": {
                    "$ref": "#/$defs/path"
                },
                "loop": {
                    "type": "array",
                    "minItems": 4,
                    "items": {
                        "$ref": "#/$defs/pdca_step"
                    }
                },
                "closure_rules": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/rule"
                    }
                }
            }
        },
        {
            "type": "object",
            "required": [
                "manifest_version",
                "generated_by",
                "subject",
                "source",
                "axes",
                "closure_rules"
            ],
            "additionalProperties": false,
            "properties": {
                "manifest_version": {
                    "$ref": "#/$defs/semver"
                },
                "generated_by": {
                    "const": "scripts/verificationcodegengen.sh"
                },
                "subject": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "source": {
                    "$ref": "#/$defs/path"
                },
                "axes": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/axis"
                    }
                },
                "closure_rules": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/rule"
                    }
                }
            }
        },
        {
            "type": "object",
            "required": [
                "manifest_version",
                "generated_by",
                "subject",
                "source",
                "ledger",
                "closure_rules"
            ],
            "additionalProperties": false,
            "properties": {
                "manifest_version": {
                    "$ref": "#/$defs/semver"
                },
                "generated_by": {
                    "const": "scripts/verificationlossgen.sh"
                },
                "subject": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "source": {
                    "$ref": "#/$defs/path"
                },
                "ledger": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/loss_entry"
                    }
                },
                "closure_rules": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/rule"
                    }
                }
            }
        },
        {
            "type": "object",
            "required": [
                "manifest_version",
                "generated_by",
                "subject",
                "source",
                "algorithm",
                "hashes",
                "closure_rules"
            ],
            "additionalProperties": false,
            "properties": {
                "manifest_version": {
                    "$ref": "#/$defs/semver"
                },
                "generated_by": {
                    "const": "scripts/verificationsemanticgen.sh"
                },
                "subject": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "source": {
                    "$ref": "#/$defs/path"
                },
                "algorithm": {
                    "const": "sha256"
                },
                "hashes": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/semantic_hash"
                    }
                },
                "closure_rules": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/rule"
                    }
                }
            }
        },
        {
            "type": "object",
            "required": [
                "manifest_version",
                "generated_by",
                "subject",
                "source",
                "base",
                "head",
                "diffs",
                "closure_rules"
            ],
            "additionalProperties": false,
            "properties": {
                "manifest_version": {
                    "$ref": "#/$defs/semver"
                },
                "generated_by": {
                    "const": "scripts/verificationdiffgen.sh"
                },
                "subject": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "source": {
                    "$ref": "#/$defs/path"
                },
                "base": {
                    "$ref": "#/$defs/path"
                },
                "head": {
                    "$ref": "#/$defs/path"
                },
                "diffs": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/semantic_diff"
                    }
                },
                "closure_rules": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/rule"
                    }
                }
            }
        },
        {
            "type": "object",
            "required": [
                "manifest_version",
                "generated_by",
                "subject",
                "source",
                "authority_profile",
                "decisions",
                "closure_rules"
            ],
            "additionalProperties": false,
            "properties": {
                "manifest_version": {
                    "$ref": "#/$defs/semver"
                },
                "generated_by": {
                    "const": "scripts/verificationauthoritygen.sh"
                },
                "subject": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "source": {
                    "$ref": "#/$defs/path"
                },
                "authority_profile": {
                    "type": "string",
                    "minLength": 1
                },
                "decisions": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/authority_decision"
                    }
                },
                "closure_rules": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/rule"
                    }
                }
            }
        },
        {
            "type": "object",
            "required": [
                "manifest_version",
                "generated_by",
                "subject",
                "source",
                "evidence_quality_profile",
                "assessments",
                "closure_rules"
            ],
            "additionalProperties": false,
            "properties": {
                "manifest_version": {
                    "$ref": "#/$defs/semver"
                },
                "generated_by": {
                    "const": "scripts/verificationevidencequalitygen.sh"
                },
                "subject": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "source": {
                    "$ref": "#/$defs/path"
                },
                "evidence_quality_profile": {
                    "type": "string",
                    "minLength": 1
                },
                "assessments": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/evidence_quality"
                    }
                },
                "closure_rules": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/rule"
                    }
                }
            }
        },
        {
            "type": "object",
            "required": [
                "manifest_version",
                "generated_by",
                "subject",
                "source",
                "lease_profile",
                "leases",
                "abort_rules",
                "closure_rules"
            ],
            "additionalProperties": false,
            "properties": {
                "manifest_version": {
                    "$ref": "#/$defs/semver"
                },
                "generated_by": {
                    "const": "scripts/verificationleasegen.sh"
                },
                "subject": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "source": {
                    "$ref": "#/$defs/path"
                },
                "lease_profile": {
                    "type": "string",
                    "minLength": 1
                },
                "leases": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/verification_lease"
                    }
                },
                "abort_rules": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/abort_rule"
                    }
                },
                "closure_rules": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/rule"
                    }
                }
            }
        },
        {
            "type": "object",
            "required": [
                "manifest_version",
                "generated_by",
                "subject",
                "source",
                "review_capacity_profile",
                "queues",
                "overload_rules",
                "closure_rules"
            ],
            "additionalProperties": false,
            "properties": {
                "manifest_version": {
                    "$ref": "#/$defs/semver"
                },
                "generated_by": {
                    "const": "scripts/verificationreviewgen.sh"
                },
                "subject": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "source": {
                    "$ref": "#/$defs/path"
                },
                "review_capacity_profile": {
                    "type": "string",
                    "minLength": 1
                },
                "queues": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/review_queue"
                    }
                },
                "overload_rules": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/review_overload"
                    }
                },
                "closure_rules": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/rule"
                    }
                }
            }
        }
    ],
    "$defs": {
        "path": {
            "type": "string",
            "minLength": 1
        },
        "semantic_ref": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_\\-]*:[a-z][a-z0-9_.\\-]*$"
        },
        "semver": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "strings": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "string",
                "minLength": 1
            }
        },
        "rule": {
            "type": "object",
            "required": [
                "id",
                "meaning",
                "check"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 1
                },
                "meaning": {
                    "type": "string",
                    "minLength": 1
                },
                "check": {
                    "type": "string",
                    "pattern": "^scripts/.+ check$"
                }
            }
        },
        "status_rule": {
            "type": "object",
            "required": [
                "id",
                "meaning",
                "check",
                "status"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 1
                },
                "meaning": {
                    "type": "string",
                    "minLength": 1
                },
                "check": {
                    "type": "string",
                    "pattern": "^scripts/.+ check$"
                },
                "status": {
                    "const": "required"
                }
            }
        },
        "axis": {
            "type": "object",
            "required": [
                "axis",
                "backends"
            ],
            "additionalProperties": false,
            "properties": {
                "axis": {
                    "type": "string",
                    "minLength": 1
                },
                "backends": {
                    "$ref": "#/$defs/strings"
                }
            }
        },
        "pdca_step": {
            "type": "object",
            "required": [
                "phase",
                "evidence",
                "artifact"
            ],
            "additionalProperties": false,
            "properties": {
                "phase": {
                    "enum": [
                        "plan",
                        "do",
                        "check",
                        "act"
                    ]
                },
                "evidence": {
                    "type": "string",
                    "minLength": 1
                },
                "artifact": {
                    "$ref": "#/$defs/path"
                }
            }
        },
        "loss_entry": {
            "type": "object",
            "required": [
                "id",
                "source",
                "target",
                "loss_level",
                "meaning",
                "evidence",
                "policy"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "source": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "target": {
                    "$ref": "#/$defs/path"
                },
                "loss_level": {
                    "enum": [
                        "L1",
                        "L2",
                        "L3"
                    ]
                },
                "meaning": {
                    "type": "string",
                    "minLength": 1
                },
                "evidence": {
                    "$ref": "#/$defs/path"
                },
                "policy": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "semantic_hash": {
            "type": "object",
            "required": [
                "id",
                "source",
                "fields",
                "meaning",
                "hash"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "source": {
                    "$ref": "#/$defs/path"
                },
                "fields": {
                    "$ref": "#/$defs/strings"
                },
                "meaning": {
                    "type": "string",
                    "minLength": 1
                },
                "hash": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$"
                }
            }
        },
        "semantic_diff": {
            "type": "object",
            "required": [
                "id",
                "hash_id",
                "summary",
                "base_hash",
                "head_hash",
                "status",
                "evidence"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "hash_id": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "summary": {
                    "type": "string",
                    "minLength": 1
                },
                "base_hash": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$"
                },
                "head_hash": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$"
                },
                "status": {
                    "enum": [
                        "unchanged",
                        "changed",
                        "blocked"
                    ]
                },
                "evidence": {
                    "$ref": "#/$defs/path"
                }
            }
        },
        "authority_decision": {
            "type": "object",
            "required": [
                "id",
                "scope",
                "decision",
                "approved_by",
                "requires",
                "evidence",
                "meaning"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "scope": {
                    "enum": [
                        "routine",
                        "release",
                        "security",
                        "audit",
                        "ontology",
                        "incident"
                    ]
                },
                "decision": {
                    "enum": [
                        "approved",
                        "escalated",
                        "rejected"
                    ]
                },
                "approved_by": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "requires": {
                    "$ref": "#/$defs/strings"
                },
                "evidence": {
                    "$ref": "#/$defs/strings"
                },
                "meaning": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "evidence_quality": {
            "type": "object",
            "required": [
                "id",
                "target",
                "quality",
                "purpose",
                "assessed_by",
                "signals",
                "meaning"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "target": {
                    "$ref": "#/$defs/path"
                },
                "quality": {
                    "enum": [
                        "high",
                        "medium",
                        "low"
                    ]
                },
                "purpose": {
                    "type": "string",
                    "minLength": 1
                },
                "assessed_by": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "signals": {
                    "$ref": "#/$defs/strings"
                },
                "meaning": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "verification_lease": {
            "type": "object",
            "required": [
                "id",
                "holder",
                "scope",
                "status",
                "authority_effect",
                "evidence",
                "meaning"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "holder": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "scope": {
                    "type": "string",
                    "minLength": 1
                },
                "status": {
                    "enum": [
                        "issued",
                        "active",
                        "finished",
                        "aborted",
                        "escalated"
                    ]
                },
                "authority_effect": {
                    "enum": [
                        "authority-after-checks",
                        "authority-blocked"
                    ]
                },
                "evidence": {
                    "$ref": "#/$defs/strings"
                },
                "meaning": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "abort_rule": {
            "type": "object",
            "required": [
                "id",
                "trigger",
                "effect",
                "meaning"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "trigger": {
                    "type": "string",
                    "minLength": 1
                },
                "effect": {
                    "const": "authority-blocked"
                },
                "meaning": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "review_queue": {
            "type": "object",
            "required": [
                "id",
                "scope",
                "capacity",
                "assigned",
                "status",
                "freezes",
                "evidence",
                "meaning"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "scope": {
                    "type": "string",
                    "minLength": 1
                },
                "capacity": {
                    "type": "integer",
                    "minimum": 0
                },
                "assigned": {
                    "type": "integer",
                    "minimum": 0
                },
                "status": {
                    "enum": [
                        "available",
                        "near-limit",
                        "overloaded"
                    ]
                },
                "freezes": {
                    "$ref": "#/$defs/strings"
                },
                "evidence": {
                    "$ref": "#/$defs/strings"
                },
                "meaning": {
                    "type": "string",
                    "minLength": 1
                }
            }
        },
        "review_overload": {
            "type": "object",
            "required": [
                "id",
                "when",
                "effect",
                "meaning"
            ],
            "additionalProperties": false,
            "properties": {
                "id": {
                    "$ref": "#/$defs/semantic_ref"
                },
                "when": {
                    "const": "overloaded"
                },
                "effect": {
                    "enum": [
                        "freeze-governed-automation",
                        "create-review-debt"
                    ]
                },
                "meaning": {
                    "type": "string",
                    "minLength": 1
                }
            }
        }
    }
}
