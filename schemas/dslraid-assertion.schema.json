{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dslraid.dev/schemas/dslraid-assertion.schema.json",
  "title": "DSLRaid Assertion Registry",
  "type": "object",
  "required": ["assertion_version", "assertions"],
  "additionalProperties": false,
  "properties": {
    "assertion_version": {
      "$ref": "#/$defs/semver"
    },
    "assertions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assertion"
      }
    }
  },
  "$defs": {
    "assertion": {
      "type": "object",
      "required": [
        "id",
        "proposition",
        "code",
        "name",
        "layer",
        "scope",
        "predicate",
        "severity",
        "subjects",
        "given",
        "check",
        "fail_if",
        "message_template",
        "fix_template"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/assertion_ref"
        },
        "proposition": {
          "$ref": "#/$defs/proposition_id"
        },
        "code": {
          "$ref": "#/$defs/diagnostic_code"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "layer": {
          "$ref": "#/$defs/layer"
        },
        "scope": {
          "type": "string",
          "enum": [
            "project",
            "context",
            "fsm",
            "state",
            "transition",
            "event",
            "guard",
            "action",
            "composition",
            "projection",
            "derivation",
            "artifact",
            "diagnostic",
            "trace",
            "coverage",
            "public_projection"
          ]
        },
        "predicate": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "subjects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "project",
              "context",
              "fsm",
              "state",
              "transition",
              "event",
              "guard",
              "action",
              "composition",
              "projection",
              "derivation",
              "artifact",
              "diagnostic",
              "trace_event",
              "coverage_subject"
            ]
          }
        },
        "given": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "check": {
          "type": "string",
          "minLength": 1
        },
        "fail_if": {
          "type": "string",
          "minLength": 1
        },
        "message_template": {
          "type": "string",
          "minLength": 1
        },
        "fix_template": {
          "type": "string",
          "minLength": 1
        },
        "evidence_schema": {
          "type": "object",
          "additionalProperties": true
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "layer": {
      "type": "string",
      "enum": [
        "ir_structure",
        "fsm",
        "guard_action",
        "composition",
        "projection",
        "traceability",
        "artifact",
        "diagnostics",
        "visibility_security",
        "runtime_trace",
        "coverage",
        "capability",
        "provider_compatibility",
        "protocol",
        "performance",
        "layout",
        "governance",
        "adr"
      ]
    },
    "severity": {
      "type": "string",
      "enum": ["hint", "info", "warning", "error"]
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "proposition_id": {
      "type": "string",
      "pattern": "^V[0-9]{3}$"
    },
    "diagnostic_code": {
      "type": "string",
      "pattern": "^[A-Z]{3}[0-9]{3}$"
    },
    "assertion_ref": {
      "type": "string",
      "pattern": "^assertion:[a-z][a-z0-9_.\\-]*$"
    }
  }
}
