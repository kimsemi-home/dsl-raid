{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dslraid.dev/schemas/dslraid-validation.schema.json",
  "title": "DSLRaid Validation Report",
  "type": "object",
  "required": ["validation_version", "source", "run", "summary", "propositions", "assertions"],
  "additionalProperties": false,
  "properties": {
    "validation_version": {
      "$ref": "#/$defs/semver"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "run": {
      "$ref": "#/$defs/run"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "propositions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/proposition_result"
      }
    },
    "assertions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assertion_result"
      }
    },
    "diagnostics": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/diagnostic_ref"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["core_ir"],
      "additionalProperties": false,
      "properties": {
        "core_ir": {
          "type": "string",
          "minLength": 1
        },
        "ir_hash": {
          "$ref": "#/$defs/hash"
        },
        "lock": {
          "type": "string",
          "minLength": 1
        },
        "assertions": {
          "type": "string",
          "minLength": 1
        },
        "projection": {
          "$ref": "#/$defs/semantic_ref"
        }
      }
    },
    "run": {
      "type": "object",
      "required": ["tool", "mode"],
      "additionalProperties": false,
      "properties": {
        "tool": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["validate", "quality", "artifact_verify", "compat_check", "trace_check"]
        },
        "deny": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/severity"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["status", "passed", "failed", "warnings", "skipped", "not_applicable"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["passed", "failed"]
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "warnings": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        },
        "not_applicable": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "proposition_result": {
      "type": "object",
      "required": ["id", "layer", "status", "severity"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/proposition_id"
        },
        "layer": {
          "type": "string",
          "enum": [
            "ir_structure",
            "fsm",
            "guard_action",
            "composition",
            "projection",
            "traceability",
            "artifact",
            "diagnostics",
            "visibility_security",
            "runtime_trace",
            "coverage",
            "capability",
            "provider_compatibility",
            "protocol",
            "performance",
            "layout",
            "governance",
            "adr"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "warning", "skipped", "not_applicable"]
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "subjects": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/semantic_ref"
          }
        },
        "diagnostics": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/diagnostic_ref"
          }
        },
        "assertions": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/assertion_ref"
          }
        },
        "message": {
          "type": "string"
        }
      }
    },
    "assertion_result": {
      "type": "object",
      "required": ["id", "proposition", "code", "predicate", "status", "severity"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/assertion_ref"
        },
        "proposition": {
          "$ref": "#/$defs/proposition_id"
        },
        "code": {
          "$ref": "#/$defs/diagnostic_code"
        },
        "predicate": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "warning", "skipped", "not_applicable"]
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "subjects": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/semantic_ref"
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": true
        },
        "message": {
          "type": "string"
        },
        "suggestion": {
          "type": "string"
        },
        "diagnostics": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/diagnostic_ref"
          }
        }
      }
    },
    "severity": {
      "type": "string",
      "enum": ["hint", "info", "warning", "error"]
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "proposition_id": {
      "type": "string",
      "pattern": "^V[0-9]{3}$"
    },
    "diagnostic_code": {
      "type": "string",
      "pattern": "^[A-Z]{3}[0-9]{3}$"
    },
    "assertion_ref": {
      "type": "string",
      "pattern": "^assertion:[a-z][a-z0-9_.\\-]*$"
    },
    "semantic_ref": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_\\-]*:[a-z][a-z0-9_.\\-]*$"
    },
    "diagnostic_ref": {
      "type": "string",
      "pattern": "^diagnostic:[a-z][a-z0-9_.\\-]*$"
    }
  }
}
