{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dslraid.dev/schemas/dslraid-agent-run.schema.json",
  "title": "DSLRaid Agent Run Manifest",
  "type": "object",
  "required": ["agent_run_version", "run", "ssot", "producer", "orchestration", "authority_gate", "lease", "evidence"],
  "additionalProperties": false,
  "properties": {
    "agent_run_version": { "$ref": "#/$defs/semver" },
    "run": { "$ref": "#/$defs/run" },
    "ssot": { "$ref": "#/$defs/ssot" },
    "producer": { "$ref": "#/$defs/agent" },
    "reviewers": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/agent" }
    },
    "agreements": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/agreement" }
    },
    "semantic_diffs": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/semantic_diff" }
    },
    "orchestration": { "$ref": "#/$defs/orchestration" },
    "authority_gate": { "$ref": "#/$defs/authority_gate" },
    "review_capacity": { "$ref": "#/$defs/review_capacity" },
    "lease": { "$ref": "#/$defs/lease" },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence" }
    },
    "artifacts": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/artifact" }
    },
    "claims": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/claim" }
    },
    "containments": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/containment" }
    },
    "debts": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/debt" }
    },
    "translations": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/translation" }
    }
  },
  "$defs": {
    "run": {
      "type": "object",
      "required": ["id", "purpose", "status"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "purpose": { "$ref": "#/$defs/text" },
        "started_at": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["proposed", "running", "verified", "rejected", "quarantined", "aborted"] }
      }
    },
    "ssot": {
      "type": "object",
      "required": ["context", "ontology_version", "core_ir"],
      "additionalProperties": false,
      "properties": {
        "context": { "$ref": "#/$defs/id" },
        "ontology_version": { "$ref": "#/$defs/semver" },
        "contract_version": { "$ref": "#/$defs/semver" },
        "core_ir": { "$ref": "#/$defs/path" },
        "core_ir_hash": { "$ref": "#/$defs/hash" },
        "revalidation": { "$ref": "#/$defs/revalidation" }
      }
    },
    "revalidation": {
      "type": "object",
      "required": ["status", "assessed_at", "assessor", "revalidate_at"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["valid", "due_soon", "due", "grace", "expired", "frozen", "revalidated", "superseded", "retired"]
        },
        "assessed_at": { "type": "string", "format": "date-time" },
        "assessor": { "$ref": "#/$defs/id" },
        "revalidate_at": { "type": "string", "format": "date-time" },
        "evidence": { "$ref": "#/$defs/id" }
      }
    },
    "agent": {
      "type": "object",
      "required": ["id", "role", "reasoning_level"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "role": { "$ref": "#/$defs/id" },
        "reasoning_level": { "type": "string", "enum": ["R0", "R1", "R2", "R3", "R4"] },
        "trust_tier": { "type": "string", "enum": ["T0", "T1", "T2", "T3", "T4"] }
      }
    },
    "authority_gate": {
      "type": "object",
      "required": ["decision", "policy_hash", "human_review_required"],
      "additionalProperties": false,
      "properties": {
        "decision": { "type": "string", "enum": ["approved", "rejected", "escalated", "blocked"] },
        "policy_hash": { "$ref": "#/$defs/hash" },
        "profile": { "type": "string", "enum": ["automatic", "sidecar", "human", "governance"] },
        "scope": { "type": "string", "enum": ["routine", "security", "audit", "ontology", "incident", "authority"] },
        "human_review_required": { "type": "boolean" },
        "approved_by": { "$ref": "#/$defs/id" },
        "evidence": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "agreement": {
      "type": "object",
      "required": ["id", "subject", "participants", "decision", "interpreted_under", "evidence"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "subject": { "$ref": "#/$defs/id" },
        "participants": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/id" }
        },
        "decision": { "type": "string", "enum": ["agree", "disagree", "escalate"] },
        "interpreted_under": { "$ref": "#/$defs/semver" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "orchestration": {
      "type": "object",
      "required": ["id", "ontology_version", "policy_hash", "routed_by", "verified_by", "selected_producer", "selected_reviewers", "lease", "authority_profile", "input_evidence", "output_artifacts", "evidence"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "ontology_version": { "$ref": "#/$defs/semver" },
        "policy_hash": { "$ref": "#/$defs/hash" },
        "routed_by": { "$ref": "#/$defs/id" },
        "verified_by": { "$ref": "#/$defs/id" },
        "selected_producer": { "$ref": "#/$defs/id" },
        "selected_reviewers": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/id" }
        },
        "lease": { "$ref": "#/$defs/id" },
        "authority_profile": { "type": "string", "enum": ["automatic", "sidecar", "human", "governance"] },
        "input_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/id" }
        },
        "output_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/id" }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "review_capacity": {
      "type": "object",
      "required": ["status", "queue_depth", "max_queue_depth", "assessed_at", "assessor", "evidence"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["available", "strained", "overloaded", "frozen"] },
        "queue_depth": { "type": "integer", "minimum": 0 },
        "max_queue_depth": { "type": "integer", "minimum": 1 },
        "assessed_at": { "type": "string", "format": "date-time" },
        "assessor": { "$ref": "#/$defs/id" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "semantic_diff": {
      "type": "object",
      "required": ["id", "base_hash", "head_hash", "status", "evidence"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "base_hash": { "$ref": "#/$defs/hash" },
        "head_hash": { "$ref": "#/$defs/hash" },
        "status": { "type": "string", "enum": ["unchanged", "changed", "blocked"] },
        "summary": { "$ref": "#/$defs/text" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "lease": {
      "type": "object",
      "required": ["id", "status", "issued_at", "expires_at"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "status": { "type": "string", "enum": ["issued", "active", "expiring", "expired", "rebase_required", "finished", "aborted", "escalated", "quarantined"] },
        "issued_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "ontology_version": { "$ref": "#/$defs/semver" }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["id", "kind", "uri", "provenance"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "type": "string", "enum": ["observation", "validation", "trace", "coverage", "artifact", "review", "decision", "debt"] },
        "uri": { "$ref": "#/$defs/path" },
        "status": { "type": "string", "enum": ["active", "archived", "pruned"] },
        "retention": { "type": "string", "enum": ["normal", "protected", "legal_hold"] },
        "quality": { "type": "string", "enum": ["low", "medium", "high"] },
        "subject": { "$ref": "#/$defs/id" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "tombstone": { "$ref": "#/$defs/evidence_tombstone" },
        "quality_snapshots": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/quality_snapshot" }
        }
      }
    },
    "evidence_tombstone": {
      "type": "object",
      "required": ["reason", "pruned_by", "pruned_at", "policy_hash"],
      "additionalProperties": false,
      "properties": {
        "reason": { "$ref": "#/$defs/text" },
        "pruned_by": { "$ref": "#/$defs/id" },
        "pruned_at": { "type": "string", "format": "date-time" },
        "policy_hash": { "$ref": "#/$defs/hash" }
      }
    },
    "quality_snapshot": {
      "type": "object",
      "required": ["assessed_at", "assessor", "purpose", "quality"],
      "additionalProperties": false,
      "properties": {
        "assessed_at": { "type": "string", "format": "date-time" },
        "assessor": { "$ref": "#/$defs/id" },
        "purpose": { "type": "string", "enum": ["authority", "root_cause", "regression", "traceability", "security"] },
        "quality": { "type": "string", "enum": ["low", "medium", "high"] },
        "revalidate_at": { "type": "string", "format": "date-time" },
        "ontology_version": { "$ref": "#/$defs/semver" },
        "notes": { "$ref": "#/$defs/text" }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["kind", "observed_by", "observed_at"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["sidecar-assessment", "runtime-trace", "generated", "external", "human-annotation"]
        },
        "observed_by": { "$ref": "#/$defs/id" },
        "observed_at": { "type": "string", "format": "date-time" }
      }
    },
    "artifact": {
      "type": "object",
      "required": ["id", "path", "status"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "path": { "$ref": "#/$defs/path" },
        "status": { "type": "string", "enum": ["candidate", "verified", "stale", "quarantined", "aborted"] }
      }
    },
    "claim": {
      "type": "object",
      "required": ["id", "subject", "statement", "confidence", "interpreted_under", "status", "evidence"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "subject": { "$ref": "#/$defs/id" },
        "statement": { "$ref": "#/$defs/text" },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "assessor": { "$ref": "#/$defs/id" },
        "interpreted_under": { "$ref": "#/$defs/semver" },
        "status": { "type": "string", "enum": ["proposed", "supported", "rejected", "superseded"] },
        "evidence": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "containment": {
      "type": "object",
      "required": ["id", "kind", "subject", "reason", "status", "owner", "opened_at", "evidence"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "type": "string", "enum": ["abort", "quarantine"] },
        "subject": { "$ref": "#/$defs/id" },
        "reason": { "$ref": "#/$defs/text" },
        "status": { "type": "string", "enum": ["open", "released", "closed"] },
        "owner": { "$ref": "#/$defs/id" },
        "opened_at": { "type": "string", "format": "date-time" },
        "released_by": { "$ref": "#/$defs/id" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/id" }
        },
        "release_conditions": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/release_condition" }
        },
        "debt": { "$ref": "#/$defs/id" }
      }
    },
    "release_condition": {
      "type": "object",
      "required": ["id", "description", "status", "evidence"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "description": { "$ref": "#/$defs/text" },
        "status": { "type": "string", "enum": ["pending", "met", "failed"] },
        "evidence": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "debt": {
      "type": "object",
      "required": ["id", "kind", "status", "owner", "opened_at", "revalidate_at"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "type": "string", "enum": ["evidence", "review", "revalidation", "quarantine", "translation"] },
        "status": { "type": "string", "enum": ["open", "closed", "waived"] },
        "owner": { "$ref": "#/$defs/id" },
        "opened_at": { "type": "string", "format": "date-time" },
        "revalidate_at": { "type": "string", "format": "date-time" },
        "closed_at": { "type": "string", "format": "date-time" },
        "evidence": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/id" }
        },
        "updates": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/knowledge_update" }
        },
        "notes": { "$ref": "#/$defs/text" }
      }
    },
    "knowledge_update": {
      "type": "object",
      "required": ["id", "kind", "subject", "status", "evidence"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "kind": { "type": "string", "enum": ["policy", "ontology", "spec", "owner", "revalidation"] },
        "subject": { "$ref": "#/$defs/id" },
        "status": { "type": "string", "enum": ["proposed", "applied", "accepted"] },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "translation": {
      "type": "object",
      "required": ["id", "source_context", "target_context", "status", "conformance", "losses"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "source_context": { "$ref": "#/$defs/id" },
        "target_context": { "$ref": "#/$defs/id" },
        "status": { "type": "string", "enum": ["lossless", "lossy", "verified", "blocked"] },
        "conformance": { "type": "string", "enum": ["source", "target", "dual", "partial"] },
        "round_trip": { "type": "boolean" },
        "approved_by": { "$ref": "#/$defs/id" },
        "evidence": {
          "type": "array",
          "default": [],
          "items": { "$ref": "#/$defs/id" }
        },
        "losses": {
          "type": "array",
          "items": { "$ref": "#/$defs/loss" }
        }
      }
    },
    "loss": {
      "type": "object",
      "required": ["id", "level", "description", "status", "evidence"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "level": { "type": "string", "enum": ["L0", "L1", "L2", "L3", "L4"] },
        "description": { "$ref": "#/$defs/text" },
        "status": { "type": "string", "enum": ["accepted", "mitigated", "forbidden"] },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/id" }
        }
      }
    },
    "id": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "text": { "type": "string", "minLength": 1 },
    "hash": { "type": "string", "pattern": "^[a-z0-9]+:[A-Za-z0-9._:-]+$" },
    "semver": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
  }
}
