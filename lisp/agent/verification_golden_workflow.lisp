(in-package #:dslraid.agent)

(defun emit-verification-golden-yaml (&optional stream)
  (let ((yaml (with-output-to-string (out) (write-verification-golden out))))
    (if stream (write-string yaml stream) yaml)))

(defun write-verification-golden (out)
  (write-golden-header out)
  (write-golden-triggers out)
  (write-golden-permissions out)
  (write-golden-job out))

(defun write-golden-header (out)
  (format out "# generated by scripts/goldengen.sh; do not edit by hand~%")
  (format out "name: Golden~%~%"))

(defun write-golden-triggers (out)
  (format out "on:~%")
  (format out "  pull_request:~%")
  (format out "  push:~%    branches: [main]~%")
  (format out "  workflow_dispatch:~%~%"))

(defun write-golden-permissions (out)
  (format out "permissions:~%  contents: read~%~%")
  (format out "concurrency:~%")
  (format out "  group: golden-${{ github.ref }}~%")
  (format out "  cancel-in-progress: true~%~%"))

(defun write-golden-job (out)
  (format out "jobs:~%")
  (format out "  golden:~%")
  (format out "    name: Golden outputs~%")
  (format out "    runs-on: ubuntu-latest~%")
  (format out "    steps:~%")
  (write-golden-steps out))

(defun write-golden-steps (out)
  (write-golden-checkout out)
  (write-golden-detect-cli out)
  (write-golden-rust out)
  (write-golden-check out)
  (write-golden-fallback out))

(defun write-golden-checkout (out)
  (format out "      - uses: actions/checkout@v6~%~%"))

(defun write-golden-detect-cli (out)
  (format out "      - name: Detect DSLRaid CLI~%")
  (format out "        id: cli~%")
  (format out "        run: |~%")
  (format out "          if [ -f Cargo.toml ] && [ -f crates/dslraid-cli/Cargo.toml ]; then~%")
  (format out "            echo \"present=true\" >> \"$GITHUB_OUTPUT\"~%")
  (format out "          else~%            echo \"present=false\" >> \"$GITHUB_OUTPUT\"~%")
  (format out "          fi~%~%"))

(defun write-golden-rust (out)
  (format out "      - uses: dtolnay/rust-toolchain@stable~%")
  (format out "        if: steps.cli.outputs.present == 'true'~%~%")
  (format out "      - uses: Swatinem/rust-cache@v2~%")
  (format out "        if: steps.cli.outputs.present == 'true'~%~%"))

(defun write-golden-check (out)
  (format out "      - name: Check golden outputs~%")
  (format out "        if: steps.cli.outputs.present == 'true'~%")
  (format out "        run: cargo run -p dslraid-cli -- golden check tests/golden~%~%"))

(defun write-golden-fallback (out)
  (format out "      - name: Bootstrap golden fallback~%")
  (format out "        if: steps.cli.outputs.present != 'true'~%")
  (format out "        run: |~%")
  (format out "          echo \"dslraid-cli is not present yet; checking JSON fixtures only.\"~%")
  (format out "          find schemas examples -name '*.json' -print0 |~%")
  (format out "            while IFS= read -r -d '' file; do~%")
  (format out "              python3 -m json.tool \"$file\" >/dev/null~%")
  (format out "            done~%"))
