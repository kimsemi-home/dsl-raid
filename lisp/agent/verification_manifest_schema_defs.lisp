   "\"meaning\":{\"type\":\"string\",\"minLength\":1},\"check\":{\"type\":\"string\",\"pattern\":\"^scripts/.+ check$\"}}},"
   "\"status_rule\":{\"type\":\"object\",\"required\":[\"id\",\"meaning\",\"check\",\"status\"],"
