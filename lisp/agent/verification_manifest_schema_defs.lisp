   "\"orchestration_route\":{\"type\":\"object\",\"required\":[\"id\",\"decision\",\"control_plane\",\"agent\",\"policy\",\"authority\",\"evidence\",\"outputs\",\"meaning\"],\"additionalProperties\":false,\"properties\":{\"id\":{\"$ref\":\"#/$defs/semantic_ref\"},\"decision\":{\"$ref\":\"#/$defs/semantic_ref\"},\"control_plane\":{\"$ref\":\"#/$defs/semantic_ref\"},\"agent\":{\"$ref\":\"#/$defs/semantic_ref\"},\"policy\":{\"$ref\":\"#/$defs/semantic_ref\"},\"authority\":{\"$ref\":\"#/$defs/semantic_ref\"},\"evidence\":{\"$ref\":\"#/$defs/strings\"},\"outputs\":{\"$ref\":\"#/$defs/strings\"},\"meaning\":{\"type\":\"string\",\"minLength\":1}}},"
