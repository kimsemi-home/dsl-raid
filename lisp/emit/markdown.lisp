(in-package #:dslraid.emit)

(defun emit-language-pipeline-markdown (&optional stream)
  "Emit deterministic Markdown for the Lisp authoring pipeline."
  (let ((markdown (with-output-to-string (out)
                    (write-language-doc out))))
    (if stream
        (write-string markdown stream)
        markdown)))

(defun write-language-doc (out)
  (format out "# DSLRaid Lisp Pipeline~%~%")
  (format out "<!-- generated by scripts/lisp-docgen.sh; do not edit by hand -->~%~%")
  (format out "Source: `lisp/lang/pipeline.lisp`~%~%")
  (format out "The Common Lisp layer is DSLRaid's native authoring surface.~%")
  (format out "It expands executable forms into Canonical IR before Rust tooling runs.~%~%")
  (write-stage-table out)
  (write-contracts out)
  (write-command out))

(defun write-stage-table (out)
  (format out "## Pipeline~%~%")
  (format out "| Stage | Contract |~%| --- | --- |~%")
  (dolist (stage (dslraid.lang:language-pipeline-catalog))
    (format out "| ~A | ~A |~%" (first stage) (second stage)))
  (terpri out))

(defun write-contracts (out)
  (format out "## Contracts~%~%")
  (dolist (contract (dslraid.lang:language-contract-catalog))
    (format out "- ~A~%" contract))
  (terpri out))

(defun write-command (out)
  (format out "## Regeneration~%~%")
  (format out "```bash~%")
  (format out "bash scripts/lisp-docgen.sh generate~%")
  (format out "bash scripts/lisp-docgen.sh check~%")
  (format out "bash scripts/lisp-irgen.sh generate~%")
  (format out "bash scripts/lisp-irgen.sh check~%")
  (format out "bash scripts/backendgen.sh check~%")
  (format out "bash scripts/lisp-rustgen.sh check~%")
  (format out "```~%"))
